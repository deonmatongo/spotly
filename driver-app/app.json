{
  "expo": {
    "name": "Spotly Driver",
    "slug": "spotly-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.spotly.driver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Spotly Driver uses your location to match you with nearby delivery jobs and to share live tracking with customers.",
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1B2A"
      },
      "package": "app.spotly.driver",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D1B2A"
        }
      ],
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Spotly Driver shares your live location with customers during an active delivery so they can track their order.",
          "locationWhenInUsePermission": "Spotly Driver uses your location to find nearby delivery jobs.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ]
  }
}
